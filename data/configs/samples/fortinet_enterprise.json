  "ips_sensor": {
    "endpoint": "/api/v2/cmdb/ips/sensor",
    "results": [
      {"name": "ips-default", "comment": "Default IPS — critical and high severity block"},
      {"name": "ips-strict",  "comment": "Strict IPS — all severities, extended signature set"},
      {"name": "ips-servers", "comment": "Server-specific IPS — server-side exploit focus"}
    ]
