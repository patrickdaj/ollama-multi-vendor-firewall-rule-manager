          {"id": 1, "application": [{"name": "P2P"}],      "action": "block", "category": "P2P"},
          {"id": 2, "application": [{"name": "Tor"}],      "action": "block", "category": "Proxy"},
          {"id": 3, "application": [{"name": "BitTorrent"}],"action": "block", "category": "P2P"},
          {"id": 4, "category": [{"id": 2}],                "action": "monitor", "category": "General Interest"},
          {"id": 5, "application": [{"name": "Office365"}, {"name": "Teams"}, {"name": "Zoom"}], "action": "pass"}
        ]
      }
