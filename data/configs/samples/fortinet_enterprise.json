  "webfilter_profile": {
    "endpoint": "/api/v2/cmdb/webfilter/profile",
    "results": [
      {"name": "webfilter-users",  "comment": "Standard web filtering for corporate users — block malicious/adult/P2P"},
      {"name": "webfilter-strict", "comment": "Strict filtering for VPN users — whitelisted categories only"}
    ]
  },

  "firewall_ssl_ssh_profile": {
    "endpoint": "/api/v2/cmdb/firewall/ssl-ssh-profile",
    "results": [
      {
        "name": "deep-inspection",
        "comment": "Full SSL/TLS inspection — forward proxy",
        "ssl": {"min-version": "tls-1.2"},
        "https": {"ports": "443"},
        "ftps": {"ports": "990"}
      },
      {
        "name": "certificate-inspection",
        "comment": "Certificate-only inspection (no content decryption) — for exempt categories",
        "ssl": {"min-version": "tls-1.1"}
      },
      {
        "name": "no-inspection",
        "comment": "No SSL inspection — for trusted internal traffic"
      }
    ]
  },

  "firewall_vip": {
    "endpoint": "/api/v2/cmdb/firewall/vip",
    "results": [
      {
        "name": "VIP-HTTPS-WEB",
        "extip": "203.0.113.10",
        "extintf": "port2",
        "mappedip": [{"range": "172.16.0.10"}],
        "mappedport": "443",
        "protocol": "tcp",
        "portforward": "enable",
        "status": "enable",
        "comment": "DNAT inbound HTTPS to DMZ web server"
