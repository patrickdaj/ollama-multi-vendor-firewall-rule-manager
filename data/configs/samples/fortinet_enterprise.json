{
  "_meta": {
    "device": "fg-fw01",
    "vendor": "fortinet",
    "version": "FortiOS 7.4.3",
    "scenario": "ACME Corp — same logical topology as pa-fw01 for cross-vendor comparison",
    "intentional_problems": [
      "Policies 20 (allow-all-temp) shadows policies 21-22",
      "Address objects 'corp-users' and 'internal-net' are duplicates (10.0.0.0/8)",
      "Address objects 'ad-server' and 'domain-controller' are duplicates (10.1.0.10)",
      "Policy 5 (allow-internal-web) uses port-based service instead of app-control"
    ]
  },

  "system_zone": {
    "endpoint": "/api/v2/cmdb/system/zone",
    "results": [
      {"name": "trust",   "interface": [{"interface-name": "port1"}], "description": "Corporate user LAN"},
      {"name": "untrust", "interface": [{"interface-name": "port2"}], "description": "Internet WAN"},
      {"name": "dmz",     "interface": [{"interface-name": "port3"}], "description": "Public-facing DMZ"},
      {"name": "servers", "interface": [{"interface-name": "port4"}], "description": "Internal server segment"},
      {"name": "vpn",     "interface": [{"interface-name": "ssl.root"}], "description": "SSL VPN tunnel zone"},
      {"name": "mgmt",    "interface": [{"interface-name": "port5"}], "description": "Management OOB"}
    ]
  },

