  "firewall_addrgrp": {
    "endpoint": "/api/v2/cmdb/firewall/addrgrp",
    "results": [
      {
        "name": "grp-all-internal",
        "member": [{"name": "corp-users"}, {"name": "server-subnet"}, {"name": "vpn-pool"}, {"name": "mgmt-subnet"}],
        "comment": "All internal address space"
      },
      {
        "name": "grp-servers",
        "member": [{"name": "ad-server"}, {"name": "db-server"}, {"name": "file-server"}, {"name": "backup-server"}],
        "comment": "Core internal servers"
      },
      {
        "name": "grp-dmz-servers",
        "member": [{"name": "web-dmz"}, {"name": "mail-dmz"}, {"name": "app-dmz"}],
        "comment": "All DMZ-hosted services"
      },
      {
        "name": "grp-pub-dns",
        "member": [{"name": "google-dns-primary"}, {"name": "cloudflare-dns"}],
        "comment": "Public DNS resolvers"
      }
    ]
  },

  "firewall_service_custom": {
    "endpoint": "/api/v2/cmdb/firewall.service/custom",
    "results": [
