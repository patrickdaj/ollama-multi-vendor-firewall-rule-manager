  "firewall_service_group": {
    "endpoint": "/api/v2/cmdb/firewall.service/group",
    "results": [
      {
        "name": "svcgrp-ad-auth",
        "member": [{"name": "LDAP"}, {"name": "LDAPS"}, {"name": "KERBEROS-TCP"}, {"name": "KERBEROS-UDP"}],
        "comment": "Active Directory authentication protocols"
      },
      {
        "name": "svcgrp-monitoring",
        "member": [{"name": "SNMP"}, {"name": "SYSLOG"}, {"name": "SYSLOG-TLS"}],
