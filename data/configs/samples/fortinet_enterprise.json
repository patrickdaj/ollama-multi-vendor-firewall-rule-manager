      {"name": "LDAPS",        "tcp-portrange": "636",  "comment": "LDAP over SSL"},
      {"name": "KERBEROS-TCP", "tcp-portrange": "88",   "comment": "Kerberos (TCP)"},
      {"name": "KERBEROS-UDP", "udp-portrange": "88",   "comment": "Kerberos (UDP)"},
      {"name": "SYSLOG-TLS",   "tcp-portrange": "6514", "comment": "Syslog over TLS (RFC 5425)"},
      {"name": "POSTGRESQL",   "tcp-portrange": "5432", "comment": "PostgreSQL database"},
      {"name": "BACKUP-AGENT", "tcp-portrange": "9102", "comment": "Veeam backup agent"},
      {"name": "WINRM",        "tcp-portrange": "5985-5986", "comment": "Windows Remote Management"}
