      {
        "name": "VIP-SMTP-MAIL",
        "extip": "203.0.113.11",
        "extintf": "port2",
        "mappedip": [{"range": "172.16.0.11"}],
        "mappedport": "25",
        "protocol": "tcp",
        "portforward": "enable",
        "status": "enable",
        "comment": "DNAT inbound SMTP to DMZ mail relay"
