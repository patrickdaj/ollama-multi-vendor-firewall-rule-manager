      {"name": "web-dmz",            "type": "ipmask", "subnet": "172.16.0.10/32",  "comment": "DMZ nginx reverse proxy"},
      {"name": "mail-dmz",           "type": "ipmask", "subnet": "172.16.0.11/32",  "comment": "DMZ postfix mail relay"},
      {"name": "app-dmz",            "type": "ipmask", "subnet": "172.16.0.12/32",  "comment": "DMZ API gateway"},
      {"name": "google-dns-primary", "type": "ipmask", "subnet": "8.8.8.8/32",      "comment": "Google DNS"},
      {"name": "cloudflare-dns",     "type": "ipmask", "subnet": "1.1.1.1/32",      "comment": "Cloudflare DNS"},
      {"name": "pub-web-vip",        "type": "ipmask", "subnet": "203.0.113.10/32", "comment": "Public IP — web VIP"},
      {"name": "pub-mail-vip",       "type": "ipmask", "subnet": "203.0.113.11/32", "comment": "Public IP — mail VIP"},
