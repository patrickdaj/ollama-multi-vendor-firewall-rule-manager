# ── Database (source of truth) ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://fwmgr:fwmgr@localhost:5432/firewall_manager
# Fernet key for device credential encryption — generate with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If unset, an ephemeral key is generated (credentials lost on restart)
ENCRYPTION_KEY=

# ── LLM provider ──────────────────────────────────────────────────────────────
# Chat:    ollama | openai | anthropic
# Embed:   ollama | openai   (Anthropic has no embedding models)
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
EMBED_PROVIDER=ollama
EMBED_MODEL=nomic-embed-text

# Ollama (used when LLM_PROVIDER or EMBED_PROVIDER = ollama)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# API keys — set whichever provider(s) you use
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=firewall_policies

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8080

# ── Task queue (Huey) ─────────────────────────────────────────────────────────
# SQLite file shared between app and worker containers via ./data volume mount
HUEY_DB_PATH=/app/data/huey.db

# ── Firewall Device Registry (JSON array of device configs) ───────────────────
# Each entry: {"name":"fw01","vendor":"paloalto","host":"10.0.0.1","username":"admin","password":"secret"}
FIREWALL_DEVICES=[]

# ── Palo Alto specific ────────────────────────────────────────────────────────
# PAN_API_KEY=                # optional; overrides username/password per device

# ── Cisco ASA / FTD ──────────────────────────────────────────────────────────
# FTD_CLIENT_ID=              # for FMC OAuth
# FTD_CLIENT_SECRET=

# ── Fortinet ─────────────────────────────────────────────────────────────────
# FORTI_VERIFY_SSL=false
