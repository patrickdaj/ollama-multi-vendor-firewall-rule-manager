# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=firewall_policies

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8080

# ── Firewall Device Registry (JSON array of device configs) ───────────────────
# Each entry: {"name":"fw01","vendor":"paloalto","host":"10.0.0.1","username":"admin","password":"secret"}
FIREWALL_DEVICES=[]

# ── Palo Alto specific ────────────────────────────────────────────────────────
# PAN_API_KEY=                # optional; overrides username/password per device

# ── Cisco ASA / FTD ──────────────────────────────────────────────────────────
# FTD_CLIENT_ID=              # for FMC OAuth
# FTD_CLIENT_SECRET=

# ── Fortinet ─────────────────────────────────────────────────────────────────
# FORTI_VERIFY_SSL=false
