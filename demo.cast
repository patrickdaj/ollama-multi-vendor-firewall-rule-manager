[0.000, "o", "\u001b[0;32m✓ Vector store: 306 documents ready\u001b[0m\r\n\u001b[0;32m✓ REST API:    http://localhost:8080\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;32m✓ MCP Server:  http://localhost:8001/sse\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[2m  Next steps:\u001b[0m\r\n"]
[0.000, "o", "\u001b[2m    Chat UI:         open http://localhost:8080 (after adding a frontend)\u001b[0m\r\n"]
[0.000, "o", "\u001b[2m    Full chat API:   curl -X POST http://localhost:8080/api/v1/chat -d '{\"session_id\":\"s1\",\"message\":\"...\"}'\u001b[0m\r\n"]
